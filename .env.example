# Head Office Reporting System example settings
#
# This file is safe to commit. Put real private values in a local .env file,
# and never upload that .env file to GitHub.

PROJECT_NAME="Head Office Reporting & Trust Reconciliation System"
ENVIRONMENT="development"

# Backend
BACKEND_HOST="127.0.0.1"
BACKEND_PORT="8000"
UPLOAD_DIR="backend/uploads"
MAX_UPLOAD_SIZE_MB="100"

# Frontend
FRONTEND_URL="http://127.0.0.1:5173"
VITE_API_BASE_URL="http://127.0.0.1:8000"

# Database
# Add your PostgreSQL connection string when PostgreSQL is ready.
DATABASE_URL=""

# Login security
# Add a long private value before authentication is enabled.
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="720"

# First Super Admin account
# These are used when the database is first created.
INITIAL_SUPER_ADMIN_EMAIL=""
INITIAL_SUPER_ADMIN_PASSWORD=""

# Weekly email reporting
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_USE_TLS="true"

# Future SINGs/Singhs API integration
# CSV/XLSX upload remains the active customer payment import method for now.
SINGS_API_BASE_URL=""
SINGS_API_KEY=""
SINGS_API_SECRET=""

# Felloh / SINGs API integration
# Use the sandbox base URL for testing, then the live URL for production.
FELLOH_API_BASE_URL="https://api.felloh.com"
FELLOH_PUBLIC_KEY=""
FELLOH_PRIVATE_KEY=""
FELLOH_ORGANISATION_ID=""

# Traveltek Fusion API integration
# Put the real username/password/sitename in Render environment variables only.
# This app retrieves bookings, so it uses the Traveltek search/retrieve endpoint.
TRAVELTEK_API_BASE_URL="https://fusionapi.traveltek.net/0.9/interface.pl"
TRAVELTEK_USERNAME=""
TRAVELTEK_PASSWORD=""
TRAVELTEK_SITENAME=""
TRAVELTEK_MAX_CALLS_PER_RUN="25"
